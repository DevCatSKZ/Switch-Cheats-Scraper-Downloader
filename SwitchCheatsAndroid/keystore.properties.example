# Release signing credentials for the Android app.
#
# Copy this file to  keystore.properties  and fill in your own values, then run
#   gradlew assembleRelease
# keystore.properties and the .keystore itself are gitignored — never commit them.

storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
